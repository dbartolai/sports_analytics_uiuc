frontend/node_modules/
frontend/.env

# React build artifacts
frontend/build/

# Python dependencies (backend)
backend/venv/
backend/.env

# Flask application cache files
backend/__pycache__

# OS-specific files (macOS, Windows)
.DS_Store
Thumbs.db

# Logs and temp files
*.log
*.swp

